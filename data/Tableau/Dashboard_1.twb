      <aliases enabled='yes' />
      <column caption='Avg Job Duration' datatype='real' name='[Calculation_1954152022466560]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([jobDurationSeconds])' />
      </column>
      <column caption='Failure Rate' datatype='real' name='[Calculation_1954152026812419]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([numFailedTasks]) / SUM([numTasks])' />
      </column>
      <column caption='Speedup' datatype='real' name='[Calculation_1954152027549700]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_1954152034656262]) / AVG([jobDurationSeconds])' />
      </column>
      <column caption='Efficiency ' datatype='real' name='[Calculation_1954152030068741]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_1954152027549700]) / COUNT([jobId])' />
      </column>
      <column caption='CoreCount' datatype='integer' name='[Calculation_1954152034656262]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([jobId])' />
      </column>
